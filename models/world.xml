<mujoco model="visnav_world">
  <compiler angle="radian" coordinate="local"/>
  <option timestep="0.01" gravity="0 0 -9.81"/>

  <asset>
    <texture name="floor_tex" type="2d" builtin="checker"
             rgb1="0.3 0.3 0.3" rgb2="0.4 0.4 0.4"
             width="512" height="512"/>
    <material name="floor_mat" texture="floor_tex"
              texrepeat="5 5" reflectance="0.1"/>
    <material name="robot_mat" rgba="0.2 0.4 0.8 1"/>
    <material name="goal_mat" rgba="1 0 0 1"/>
    <material name="obstacle_mat" rgba="0 1 0 1"/>
  </asset>

  <worldbody>
    <light diffuse="0.8 0.8 0.8" pos="0 0 4" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="5 5 0.1"
          material="floor_mat" condim="3"/>

    <!-- Walls -->
    <geom name="wall_n" type="box" size="5 0.1 0.5"
          pos="0 5 0.5"  rgba="0.5 0.5 0.5 1"/>
    <geom name="wall_s" type="box" size="5 0.1 0.5"
          pos="0 -5 0.5" rgba="0.5 0.5 0.5 1"/>
    <geom name="wall_e" type="box" size="0.1 5 0.5"
          pos="5 0 0.5"  rgba="0.5 0.5 0.5 1"/>
    <geom name="wall_w" type="box" size="0.1 5 0.5"
          pos="-5 0 0.5" rgba="0.5 0.5 0.5 1"/>

    <!-- Robot -->
    <body name="robot" pos="0 0 0.1">
      <joint name="root_x" type="slide" axis="1 0 0"/>
      <joint name="root_y" type="slide" axis="0 1 0"/>
      <joint name="root_z" type="slide" axis="0 0 1"/>
      <joint name="root_rot" type="hinge" axis="0 0 1"/>

      <geom name="chassis" type="cylinder"
            size="0.2 0.05" material="robot_mat"/>

      <!-- Left wheel -->
      <body name="left_wheel" pos="0 0.2 0">
        <joint name="left_wheel_joint" type="hinge"
               axis="0 1 0"/>
        <geom name="left_wheel_geom" type="cylinder"
              size="0.05 0.02" rgba="0.1 0.1 0.1 1"/>
      </body>

      <!-- Right wheel -->
      <body name="right_wheel" pos="0 -0.2 0">
        <joint name="right_wheel_joint" type="hinge"
               axis="0 1 0"/>
        <geom name="right_wheel_geom" type="cylinder"
              size="0.05 0.02" rgba="0.1 0.1 0.1 1"/>
      </body>

      <!-- Camera -->
      <camera name="robot_cam" pos="0.2 0 0.05"
              fovy="60" zaxis="-1 0 0"/>

      <!-- LiDAR site -->
      <site name="lidar_site" pos="0.2 0 0.05"
            size="0.01" rgba="1 1 0 1"/>
    </body>

    <!-- Goal marker -->
    <body name="goal" pos="3 3 0.1">
      <geom name="goal_geom" type="cylinder"
            size="0.2 0.1" material="goal_mat"/>
    </body>

    <!-- Dynamic obstacles -->
    <body name="obstacle1" pos="1 1 0.1">
      <joint name="obs1_x" type="slide" axis="1 0 0"/>
      <joint name="obs1_y" type="slide" axis="0 1 0"/>
      <geom name="obs1_geom" type="cylinder"
            size="0.15 0.1" material="obstacle_mat"/>
    </body>

    <body name="obstacle2" pos="-1 2 0.1">
      <joint name="obs2_x" type="slide" axis="1 0 0"/>
      <joint name="obs2_y" type="slide" axis="0 1 0"/>
      <geom name="obs2_geom" type="cylinder"
            size="0.15 0.1" material="obstacle_mat"/>
    </body>

    <body name="obstacle3" pos="2 -1 0.1">
      <joint name="obs3_x" type="slide" axis="1 0 0"/>
      <joint name="obs3_y" type="slide" axis="0 1 0"/>
      <geom name="obs3_geom" type="cylinder"
            size="0.15 0.1" material="obstacle_mat"/>
    </body>

  </worldbody>

  <actuator>
    <velocity name="left_wheel_motor"
              joint="left_wheel_joint"
              kv="100"/>
    <velocity name="right_wheel_motor"
              joint="right_wheel_joint"
              kv="100"/>
  </actuator>

  <sensor>
    <rangefinder name="lidar_front"
                 site="lidar_site"
                 cutoff="5.0"/>
  </sensor>

</mujoco>
